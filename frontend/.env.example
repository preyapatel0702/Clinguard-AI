# Copy this file to `.env.local` (or `.env`) and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to client code.

# Base URL for all API requests (see src/api/client.ts). Used by every
# service in the app, not just chat.
VITE_API_BASE_URL=/api

# Only used in local dev. The FastAPI backend mounts every route at the
# root (no /api prefix) - vite.config.ts proxies VITE_API_BASE_URL's
# "/api" prefix to this origin (stripping the prefix) so the browser can
# call a same-origin path in dev without CORS issues. In production,
# point VITE_API_BASE_URL directly at the deployed backend origin instead
# and this variable is unused.
VITE_BACKEND_ORIGIN=http://localhost:8000

# Path appended to VITE_API_BASE_URL for chat completions, called by
# src/services/chat/chatApi.ts on every send — there is no mock fallback,
# so this must point at a real, deployed chat endpoint.
VITE_CHAT_ENDPOINT=/chat/messages

# Path appended to VITE_API_BASE_URL for a single audit report, called by
# src/services/audit/auditApi.ts as
# `${VITE_AUDIT_SESSION_ENDPOINT}/{session_id}` (and
# `/{session_id}/export/json` | `/{session_id}/export/pdf` for exports).
VITE_AUDIT_SESSION_ENDPOINT=/audit

# Path appended to VITE_API_BASE_URL for a patient's audit history, called
# as `${VITE_AUDIT_HISTORY_ENDPOINT}/{patient_id}`.
VITE_AUDIT_HISTORY_ENDPOINT=/audit-history

# Path appended to VITE_API_BASE_URL for monitoring metrics, called by
# src/services/monitoring/monitoringApi.ts as
# `${VITE_METRICS_ENDPOINT}/overview|risk-trends|hallucinations|validations|performance|agents`.
VITE_METRICS_ENDPOINT=/metrics

# Path appended to VITE_API_BASE_URL for health checks, called as
# `${VITE_HEALTH_ENDPOINT}` and `${VITE_HEALTH_ENDPOINT}/pipeline|storage|models`.
VITE_HEALTH_ENDPOINT=/health

# Path appended to VITE_API_BASE_URL for a session's pipeline execution
# report, called by src/services/pipeline/pipelineApi.ts as
# `${VITE_PIPELINE_SESSION_ENDPOINT}/{session_id}`. Defaults to the same
# `/audit` route the Audit module uses (`GET /audit/{session_id}`), since
# the Pipeline module renders the same session record as an agent
# execution graph rather than a decision trace.
VITE_PIPELINE_SESSION_ENDPOINT=/audit
